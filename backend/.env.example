# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Port the Express server listens on (optional — defaults to 8000)
PORT=8000

# LiveKit credentials — obtain from your LiveKit Cloud project dashboard
# or self-hosted LiveKit server configuration
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LiveKit server WebSocket URL (wss:// for cloud, ws:// for local dev)
LIVEKIT_URL=wss://<your-project>.livekit.cloud

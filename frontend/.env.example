# URL of the backend Express server
# Development default: http://localhost:8000
# Production: set this to your deployed backend URL (e.g. https://your-app.up.railway.app)
REACT_APP_SERVER_URL=http://localhost:8000

# LiveKit server WebSocket URL — must match LIVEKIT_URL in backend/.env
# Obtain from your LiveKit Cloud project dashboard or self-hosted server
REACT_APP_LIVEKIT_URL=wss://<your-project>.livekit.cloud
